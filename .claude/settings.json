{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(node:*)",
      "Bash(pnpm:*)",
      "Bash(yarn:*)",
      "Bash(dotnet:*)",
      "Bash(ng:*)",
      "Bash(python:*)",
      "Bash(python3:*)",
      "Bash(pip:*)",
      "Bash(uv:*)",
      "Bash(poetry:*)",
      "Bash(pytest:*)",
      "Bash(ruff:*)",
      "Bash(mypy:*)",
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git checkout:*)",
      "Bash(gh:*)",
      "Bash(docker:*)",
      "Bash(docker-compose:*)",
      "Bash(docker compose:*)",
      "Bash(terraform fmt:*)",
      "Bash(terraform validate:*)",
      "Bash(terraform plan:*)",
      "Bash(aws s3 ls:*)",
      "Bash(aws s3api list-*)",
      "Bash(aws dynamodb list-*)",
      "Bash(aws dynamodb describe-*)",
      "Bash(aws lambda list-*)",
      "Bash(aws lambda get-*)",
      "Bash(aws sts get-caller-identity)",
      "Bash(aws bedrock list-*)",
      "Bash(aws bedrock-runtime invoke-model:*)",
      "Bash(ls:*)",
      "Bash(pwd)",
      "Bash(cat:*)",
      "Read(*)",
      "Write(*)",
      "Edit(*)",
      "Glob(*)",
      "Grep(*)"
    ],
    "ask": [
      "Bash(terraform apply:*)",
      "Bash(terraform destroy:*)",
      "Bash(aws s3 rm:*)",
      "Bash(aws s3 cp:*)",
      "Bash(aws s3 sync:*)",
      "Bash(aws dynamodb delete-*)",
      "Bash(aws dynamodb put-item:*)",
      "Bash(aws lambda delete-*)",
      "Bash(aws lambda update-*)",
      "Bash(aws lambda create-*)",
      "Bash(git push:*)",
      "Bash(gh pr create:*)",
      "Bash(gh pr merge:*)",
      "Bash(docker system prune:*)",
      "Bash(rm:*)"
    ],
    "deny": [
      "Bash(curl:* api.openai.com*)",
      "Bash(curl:* api.anthropic.com*)",
      "Bash(curl:* generativelanguage.googleapis.com*)",
      "Read(.env)",
      "Read(.env.*)",
      "Read(**/*.pem)",
      "Read(**/credentials)",
      "Read(**/.aws/credentials)"
    ]
  },
  "env": {
    "AWS_REGION": "us-east-1",
    "BEDROCK_REGION": "us-east-1",
    "LANG": "pt_BR.UTF-8"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/session-start.mjs"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/auto-format.mjs"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/pre-git-push.mjs"
          }
        ]
      }
    ]
  }
}
